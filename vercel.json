{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/track.html" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "30 15 * * *"
    }
  ],
  "functions": {
    "api/webhook.js": {
      "maxDuration": 10
    },
    "api/cron.js": {
      "maxDuration": 30
    },
    "api/setup.js": {
      "maxDuration": 10
    }
  }
}
